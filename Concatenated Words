#Given an array of strings words (without duplicates), return all the concatenated words in the given list of words.
class Solution:
    def findAllConcatenatedWordsInADict(self, words: List[str]) -> List[str]:
        s = set(words)
        concatenateWords = []
        memo = {}
        
        for word in words:
            s.remove(word)
            if self.checkConcatenate(word, s, memo):
                concatenateWords.append(word)
            s.add(word)
            
        return concatenateWords

    def checkConcatenate(self, word: str, s: set, memo: dict) -> bool:
        if word in memo:
            return memo[word]
            
        for i in range(1, len(word)):
            prefixWord = word[:i]
            suffixWord = word[i:]
            
            if prefixWord in s:
                if suffixWord in s or self.checkConcatenate(suffixWord, s, memo):
                    memo[word] = True
                    return True
                    
        memo[word] = False
        return False
