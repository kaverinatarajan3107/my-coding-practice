#Given a string s, find the length of the longest without duplicate characters.
class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        if not s:
            return 0
            
        c = []
        for i in range(len(s)):
            d = s[i]
            c.append(len(d))
            for j in range(i + 1, len(s)):
                if s[j] not in d:
                    d = d + s[j]
                    c.append(len(d))
                else:
                    break
                    
        return max(c)
