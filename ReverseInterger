#reversing a signed 32 bit interger 
class Solution:
    def reverse(self, x: int) -> int:
        rev =0
        x1=abs(x)
        while x1!=0:
            rem=x1%10
            x1=x1//10
            rev=(rev*10)+rem
        if x<0:
            rev=rev*-1 
        if - pow(2,31) <= rev <= pow(2,31) - 1:
            return rev
        else:
            return 0
        
