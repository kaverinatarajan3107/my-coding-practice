#zigzagconvesion
class Solution(object):
    def convert(self, s, numRows):
        """
        :type s: str
        :type numRows: int
        :rtype: str
        """
        if numRows==1:
            return s
        else:
            count=0
            for i in s:
                count=count+1
            l=count
            arr=[]
            for i in s:
                arr.append("")
            row=0
            for i in range(l):
                arr[row]+= s[i]
                if row==numRows-1:
                    down=False
                elif row == 0:
                    down = True
                if down:
                    row+=1
                else:
                    row-=1
            return "".join(arr)

            
    
